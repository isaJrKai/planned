# Database — PostgreSQL (Neon, Supabase, or local Postgres)
# Get a free Neon database at https://neon.tech
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# JWT signing secret. REQUIRED. Generate with:
# node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-to-a-long-random-string

# Canonical founder email. Pre-fills /setup form.
FOUNDER_EMAIL=founder@example.com

# Set to "production" for production deployments.
NODE_ENV=development

# Set to "true" in production to disable the founder:recover script.
DISABLE_FOUNDER_RECOVERY=false
